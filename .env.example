# Copy this file to .env and fill in your keys.
# .env is git-ignored — never commit actual API keys.

# ── Alpha Vantage (price cross-validation) ───────────────────────────────
# Free tier: 25 requests/day per key.  3 keys = 75 req/day total (covers 33 tickers).
# Free keys: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY_1=your_first_key_here
ALPHA_VANTAGE_API_KEY_2=your_second_key_here
ALPHA_VANTAGE_API_KEY_3=your_third_key_here

# ── Groq (search term generation for Google Trends) ──────────────────────
# Used once per new ticker to pick the best search keyword; results cached.
# Fallback: "<ticker> stock" if key is absent.
# Free key: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# ── Google Trends ────────────────────────────────────────────────────────
# No API key required. Uses pytrends (unofficial Google Trends client).
